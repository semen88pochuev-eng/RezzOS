#!/bin/sh
# RezzOS Swap File Manager (rezz-swap)

BOLD='\033[1m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
BLUE='\033[1;34m'
NC='\033[0m'

SWAPFILE="/mnt/disk/swapfile"
[ -d /mnt/disk ] || SWAPFILE="/swapfile"

usage() {
    echo -e "${BLUE}=== RezzOS Swap Manager (swap) ===${NC}"
    echo "Usage:"
    echo "  swap create [size]   - Create & enable swap file (default: 512M, e.g. 256M, 1G)"
    echo "  swap on              - Enable existing swap file"
    echo "  swap off             - Disable swap file"
    echo "  swap status          - Show memory & swap status"
    echo "  swap remove          - Disable and delete swap file"
}

create_swap() {
    SIZE="${1:-512M}"
    
    if [ -f "$SWAPFILE" ]; then
        echo -e "${YELLOW}Swap file already exists at $SWAPFILE.${NC}"
        echo "Use 'swap on' to enable it, or 'swap remove' first."
        return 1
    fi

    echo -e "${YELLOW}Creating $SIZE swap file at $SWAPFILE...${NC}"
    
    # Try fallocate first, fallback to dd
    if ! fallocate -l "$SIZE" "$SWAPFILE" 2>/dev/null; then
        num=$(echo "$SIZE" | sed 's/[^0-9]//g')
        unit=$(echo "$SIZE" | sed 's/[0-9]//g' | tr '[:lower:]' '[:upper:]')
        [ -z "$num" ] && num=512
        [ "$unit" = "G" ] && bs="1M" count=$(( num * 1024 )) || { bs="1M"; count="$num"; }
        
        dd if=/dev/zero of="$SWAPFILE" bs="$bs" count="$count" status=none 2>/dev/null || \
        dd if=/dev/zero of="$SWAPFILE" bs=1M count=512 2>/dev/null
    fi

    if [ ! -f "$SWAPFILE" ]; then
        echo -e "${RED}Failed to create swap file at $SWAPFILE.${NC}"
        return 1
    fi

    chmod 600 "$SWAPFILE"
    echo -e "${YELLOW}Setting up swap area...${NC}"
    mkswap "$SWAPFILE" >/dev/null 2>&1

    echo -e "${YELLOW}Enabling swap...${NC}"
    if swapon "$SWAPFILE" 2>/dev/null; then
        echo -e "${GREEN}Swap file ($SIZE) successfully created and activated!${NC}"
    else
        echo -e "${RED}Failed to activate swap file.${NC}"
        return 1
    fi
}

enable_swap() {
    if [ ! -f "$SWAPFILE" ]; then
        echo -e "${RED}No swap file found at $SWAPFILE.${NC}"
        echo "Run 'swap create [size]' to create one."
        return 1
    fi
    if swapon "$SWAPFILE" 2>/dev/null; then
        echo -e "${GREEN}Swap activated ($SWAPFILE).${NC}"
    else
        echo -e "${YELLOW}Swap is already active or failed to enable.${NC}"
    fi
}

disable_swap() {
    if swapoff "$SWAPFILE" 2>/dev/null || swapoff -a 2>/dev/null; then
        echo -e "${GREEN}Swap disabled.${NC}"
    else
        echo -e "${YELLOW}No active swap file to disable.${NC}"
    fi
}

show_status() {
    echo -e "${BLUE}=== Memory & Swap Status ===${NC}"
    free -h 2>/dev/null || free
    echo ""
    if [ -f /proc/swaps ] && grep -q -v "^Filename" /proc/swaps 2>/dev/null; then
        echo -e "${GREEN}Active Swaps:${NC}"
        cat /proc/swaps
    else
        echo -e "${YELLOW}No active swap partitions or files.${NC}"
    fi
}

remove_swap() {
    echo -e "${YELLOW}Disabling swap...${NC}"
    disable_swap >/dev/null 2>&1
    if [ -f "$SWAPFILE" ]; then
        rm -f "$SWAPFILE"
        echo -e "${GREEN}Swap file ($SWAPFILE) removed successfully.${NC}"
    else
        echo -e "${YELLOW}No swap file found to remove.${NC}"
    fi
}

case "$1" in
    create)   create_swap "$2" ;;
    on|enable) enable_swap ;;
    off|disable) disable_swap ;;
    status)   show_status ;;
    remove|delete) remove_swap ;;
    *)        usage ;;
esac
