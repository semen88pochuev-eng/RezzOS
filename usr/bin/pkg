#!/bin/sh
# RezzOS Package Manager (pkg)
# Downloads & installs Alpine Linux packages (.apk) with index caching & dependency support

CACHE_DIR="/var/cache/pkg"
PKG_DIR="/mnt/disk/packages"
INSTALLED_LIST="$PKG_DIR/installed.list"
[ -d "$PKG_DIR" ] || INSTALLED_LIST="/var/log/installed.list"

ALPINE_VER="v3.20"
ARCH="x86_64"
REPO_MAIN="https://dl-cdn.alpinelinux.org/alpine/${ALPINE_VER}/main/${ARCH}"
REPO_COMMUNITY="https://dl-cdn.alpinelinux.org/alpine/${ALPINE_VER}/community/${ARCH}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

mkdir -p "$CACHE_DIR" /tmp/pkg 2>/dev/null

usage() {
    echo -e "${BLUE}=== RezzOS Package Manager (pkg) ===${NC}"
    echo "Usage:"
    echo "  pkg update                 - Refresh package indexes from Alpine repos"
    echo "  pkg install <package>      - Install package (e.g. pkg install nano)"
    echo "  pkg search <query>         - Search for available packages"
    echo "  pkg info <package>         - Show detailed info about a package"
    echo "  pkg list                   - List installed packages"
    echo "  pkg remove <package>       - Uninstall package and remove files from disk"
}

update_index() {
    echo -e "${YELLOW}Updating package indexes...${NC}"
    mkdir -p "$CACHE_DIR"
    
    echo -n "Fetching main index... "
    if wget -q --no-check-certificate "$REPO_MAIN/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_main.tar.gz" 2>/dev/null || \
       wget -q "$REPO_MAIN/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_main.tar.gz" 2>/dev/null; then
        tar -xzf "$CACHE_DIR/APKINDEX_main.tar.gz" -C "$CACHE_DIR" 2>/dev/null
        mv "$CACHE_DIR/APKINDEX" "$CACHE_DIR/APKINDEX_main" 2>/dev/null
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FAILED${NC}"
    fi

    echo -n "Fetching community index... "
    if wget -q --no-check-certificate "$REPO_COMMUNITY/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_community.tar.gz" 2>/dev/null || \
       wget -q "$REPO_COMMUNITY/APKINDEX.tar.gz" -O "$CACHE_DIR/APKINDEX_community.tar.gz" 2>/dev/null; then
        tar -xzf "$CACHE_DIR/APKINDEX_community.tar.gz" -C "$CACHE_DIR" 2>/dev/null
        mv "$CACHE_DIR/APKINDEX" "$CACHE_DIR/APKINDEX_community" 2>/dev/null
        echo -e "${GREEN}OK${NC}"
    else
        echo -e "${RED}FAILED${NC}"
    fi
}

ensure_index() {
    if [ ! -f "$CACHE_DIR/APKINDEX_main" ] && [ ! -f "$CACHE_DIR/APKINDEX_community" ]; then
        update_index
    fi
}

search_pkg() {
    QUERY="$1"
    if [ -z "$QUERY" ]; then
        echo "Please specify a search query."
        return 1
    fi
    ensure_index

    echo -e "${BLUE}Search results for '${QUERY}':${NC}"
    for idx in "$CACHE_DIR/APKINDEX_main" "$CACHE_DIR/APKINDEX_community"; do
        [ -f "$idx" ] || continue
        awk -v q="$QUERY" '
            BEGIN { RS=""; FS="\n" }
            IGNORECASE = 1
            $0 ~ q {
                pkg=""; ver=""; desc=""
                for (i=1; i<=NF; i++) {
                    if ($i ~ /^P:/) pkg=substr($i,3)
                    if ($i ~ /^V:/) ver=substr($i,3)
                    if ($i ~ /^T:/) desc=substr($i,3)
                }
                if (pkg ~ q || desc ~ q) {
                    printf "\033[1;32m%-22s\033[0m \033[0;33m%-15s\033[0m %s\n", pkg, ver, desc
                }
            }
        ' "$idx"
    done
}

get_pkg_info() {
    NAME="$1"
    ensure_index
    for idx in "$CACHE_DIR/APKINDEX_main" "$CACHE_DIR/APKINDEX_community"; do
        [ -f "$idx" ] || continue
        awk -v pkg="$NAME" '
            BEGIN { RS=""; FS="\n" }
            $0 ~ ("P:" pkg "$") || $0 ~ ("P:" pkg "\n") {
                for (i=1; i<=NF; i++) {
                    if ($i ~ /^P:/) print "Package     : " substr($i,3)
                    if ($i ~ /^V:/) print "Version     : " substr($i,3)
                    if ($i ~ /^T:/) print "Description : " substr($i,3)
                    if ($i ~ /^U:/) print "URL         : " substr($i,3)
                    if ($i ~ /^D:/) print "Dependencies: " substr($i,3)
                    if ($i ~ /^S:/) print "Size (bytes): " substr($i,3)
                }
            }
        ' "$idx"
    done
}

find_pkg_details() {
    NAME="$1"
    ensure_index
    for repo in "$REPO_MAIN:$CACHE_DIR/APKINDEX_main" "$REPO_COMMUNITY:$CACHE_DIR/APKINDEX_community"; do
        url="${repo%%:*}"
        idx="${repo#*:}"
        [ -f "$idx" ] || continue

        res=$(awk -v pkg="$NAME" '
            BEGIN { RS=""; FS="\n" }
            {
                p=""; v=""; d=""
                for (i=1; i<=NF; i++) {
                    if ($i ~ /^P:/) p=substr($i,3)
                    if ($i ~ /^V:/) v=substr($i,3)
                    if ($i ~ /^D:/) d=substr($i,3)
                }
                if (p == pkg) {
                    print v "|" d
                    exit
                }
            }
        ' "$idx")

        if [ -n "$res" ]; then
            ver="${res%%|*}"
            deps="${res#*|}"
            echo "$url|${NAME}-${ver}.apk|$deps"
            return 0
        fi
    done
    return 1
}

install_single_apk() {
    URL="$1"
    APK="$2"

    echo -e "${YELLOW}Downloading ${APK}...${NC}"
    mkdir -p /tmp/pkg_dl /tmp/pkg_extract
    dl_file="/tmp/pkg_dl/${APK}"

    if [ -f "$PKG_DIR/$APK" ]; then
        cp "$PKG_DIR/$APK" "$dl_file"
    else
        wget -q --no-check-certificate "$URL/$APK" -O "$dl_file" 2>/dev/null || \
        wget -q "$URL/$APK" -O "$dl_file" 2>/dev/null
    fi

    if [ ! -s "$dl_file" ]; then
        echo -e "${RED}Failed to download ${APK}${NC}"
        return 1
    fi

    if [ -d "$PKG_DIR" ]; then
        mkdir -p "$PKG_DIR"
        cp "$dl_file" "$PKG_DIR/$APK" 2>/dev/null || true
    fi

    echo -e "${YELLOW}Extracting and installing ${APK}...${NC}"
    cd /tmp/pkg_extract
    rm -rf ./*
    tar -xzf "$dl_file" 2>/dev/null || tar -xf "$dl_file" 2>/dev/null

    [ -d usr ] && cp -r usr/* /usr/ 2>/dev/null || true
    [ -d bin ] && cp -r bin/* /bin/ 2>/dev/null || true
    [ -d sbin ] && cp -r sbin/* /sbin/ 2>/dev/null || true
    [ -d lib ] && cp -r lib/* /lib/ 2>/dev/null || true
    [ -d etc ] && cp -r etc/* /etc/ 2>/dev/null || true

    mkdir -p "$(dirname "$INSTALLED_LIST")"
    if ! grep -q "^${APK}$" "$INSTALLED_LIST" 2>/dev/null; then
        echo "${APK}" >> "$INSTALLED_LIST"
    fi

    rm -rf /tmp/pkg_extract/* "$dl_file"
    echo -e "${GREEN}Successfully installed ${APK}${NC}"
    return 0
}

install_pkg() {
    PKG_NAME="$1"
    if [ -z "$PKG_NAME" ]; then
        echo "Please specify a package name."
        return 1
    fi

    if echo "$PKG_NAME" | grep -q "\.apk$"; then
        install_single_apk "$REPO_MAIN" "$PKG_NAME" || install_single_apk "$REPO_COMMUNITY" "$PKG_NAME"
        return $?
    fi

    details=$(find_pkg_details "$PKG_NAME")
    if [ -z "$details" ]; then
        echo -e "${RED}Package '$PKG_NAME' not found in repositories.${NC}"
        echo "Try running 'pkg update' or check the spelling."
        return 1
    fi

    url=$(echo "$details" | cut -d'|' -f1)
    apk=$(echo "$details" | cut -d'|' -f2)
    deps=$(echo "$details" | cut -d'|' -f3)

    if [ -n "$deps" ]; then
        for dep in $deps; do
            case "$dep" in
                so:*|cmd:*|pc:*) continue ;;
                *)
                    dep_name=$(echo "$dep" | sed 's/[<>=].*//')
                    if [ -n "$dep_name" ] && [ "$dep_name" != "$PKG_NAME" ]; then
                        if ! grep -q "^${dep_name}-" "$INSTALLED_LIST" 2>/dev/null; then
                            echo -e "${BLUE}Resolving dependency: ${dep_name}${NC}"
                            dep_details=$(find_pkg_details "$dep_name")
                            if [ -n "$dep_details" ]; then
                                d_url=$(echo "$dep_details" | cut -d'|' -f1)
                                d_apk=$(echo "$dep_details" | cut -d'|' -f2)
                                install_single_apk "$d_url" "$d_apk"
                            fi
                        fi
                    fi
                    ;;
            esac
        done
    fi

    install_single_apk "$url" "$apk"
}

remove_pkg() {
    PKG_NAME="$1"
    if [ -z "$PKG_NAME" ]; then
        echo "Please specify a package to remove."
        return 1
    fi

    PKG_BASE=$(echo "$PKG_NAME" | sed 's/\.apk$//')

    found_apks=""
    if [ -d "$PKG_DIR" ]; then
        for f in "$PKG_DIR/${PKG_BASE}.apk" "$PKG_DIR/${PKG_BASE}"-[0-9]*.apk "$PKG_DIR/${PKG_BASE}"; do
            if [ -f "$f" ]; then
                found_apks="$found_apks $f"
            fi
        done
    fi

    removed_any=0

    for apk_file in $found_apks; do
        [ -f "$apk_file" ] || continue
        echo -e "${YELLOW}Removing installed files for $(basename "$apk_file")...${NC}"
        
        for item in $(tar -tzf "$apk_file" 2>/dev/null || tar -tf "$apk_file" 2>/dev/null); do
            clean_item=$(echo "$item" | sed 's/^\.\///; s/^\///')
            case "$clean_item" in
                .PKGINFO*|.SIGN*|.DIR*|"") continue ;;
            esac
            
            target="/$clean_item"
            if [ -f "$target" ] || [ -L "$target" ]; then
                rm -f "$target"
            fi
        done

        apk_filename=$(basename "$apk_file")
        rm -f "$apk_file"

        if [ -f "$INSTALLED_LIST" ]; then
            sed -i "/^${apk_filename}$/d" "$INSTALLED_LIST"
            sed -i "/^${PKG_BASE}$/d" "$INSTALLED_LIST"
        fi

        removed_any=1
        echo -e "${GREEN}Successfully removed ${apk_filename} and deleted saved package from disk.${NC}"
    done

    if [ "$removed_any" -eq 0 ]; then
        if [ -f "$INSTALLED_LIST" ] && grep -q -E "^(${PKG_BASE}|${PKG_BASE}-[0-9].*)$" "$INSTALLED_LIST" 2>/dev/null; then
            sed -i "/^${PKG_BASE}/d" "$INSTALLED_LIST"
            echo -e "${GREEN}Removed ${PKG_BASE} from installed packages record.${NC}"
            removed_any=1
        fi
    fi

    if [ "$removed_any" -eq 0 ]; then
        echo -e "${RED}Package '$PKG_NAME' is not installed.${NC}"
        return 1
    fi
}

list_installed() {
    if [ -f "$INSTALLED_LIST" ] && [ -s "$INSTALLED_LIST" ]; then
        echo -e "${BLUE}=== Installed Packages ===${NC}"
        cat "$INSTALLED_LIST"
    else
        echo "No packages installed yet."
    fi
}

case "$1" in
    update)               update_index ;;
    install)              [ -z "$2" ] && usage || install_pkg "$2" ;;
    search)               [ -z "$2" ] && usage || search_pkg "$2" ;;
    info)                 [ -z "$2" ] && usage || get_pkg_info "$2" ;;
    remove|uninstall)     [ -z "$2" ] && usage || remove_pkg "$2" ;;
    list)                 list_installed ;;
    *)                    usage ;;
esac
