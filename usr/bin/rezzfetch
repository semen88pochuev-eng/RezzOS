#!/bin/bash

BLUE='\033[1;34m'
WHITE='\033[1;37m'
CYAN='\033[1;36m'
NC='\033[0m'

OS="RezzOS"
KERNEL=$(uname -r)
ARCH=$(uname -m)
UPTIME=$(awk '{print int($1/3600)"h "int(($1%3600)/60)"m"}' /proc/uptime)
CPU=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo | sed 's/  */ /g')
[ -z "$CPU" ] && CPU="Unknown CPU"

MEM_TOTAL=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
MEM_FREE=$(awk '/MemFree/ {print $2}' /proc/meminfo)
if [ -n "$MEM_TOTAL" ] && [ -n "$MEM_FREE" ]; then
    MEM_USED=$(( (MEM_TOTAL - MEM_FREE) / 1024 ))
    MEM_TOTAL=$(( MEM_TOTAL / 1024 ))
    MEMORY="${MEM_USED}MB / ${MEM_TOTAL}MB"
else
    MEMORY="Unknown"
fi

echo ""
echo -e "${WHITE}  RRRRRRRRR    ${NC} ${CYAN}OS:${NC} $OS"
echo -e "${WHITE}  RR      RR   ${NC} ${CYAN}Arch:${NC} $ARCH"
echo -e "${WHITE}  RR      RR   ${NC} ${CYAN}Kernel:${NC} $KERNEL"
echo -e "${WHITE}  RRRRRRRRR    ${NC} ${CYAN}Uptime:${NC} $UPTIME"
echo -e "${WHITE}  RR   RR      ${NC} ${CYAN}CPU:${NC} $CPU"
echo -e "${WHITE}  RR    RR     ${NC} ${CYAN}Memory:${NC} $MEMORY"
echo -e "${WHITE}  RR     RR    ${NC}"
echo -e "${WHITE}  RR      RRezz ${BLUE}OS${NC}"
echo ""
