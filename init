#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs dev /dev
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts 2>/dev/null || true

hostname rezzos
echo 0 > /proc/sys/kernel/printk

# Create group and user safely
if ! grep -q "^user:" /etc/passwd 2>/dev/null; then
    echo "user:x:1000:" >> /etc/group
    echo "user:x:1000:1000:User:/home/user:/bin/sh" >> /etc/passwd
    mkdir -p /home/user
    chown -R 1000:1000 /home/user
fi

# Network - DHCP
ifconfig lo 127.0.0.1 up
ifconfig eth0 up
udhcpc -b -i eth0
echo "nameserver 8.8.8.8" > /etc/resolv.conf

# Mount disk safely
mkdir -p /mnt/disk
mount /dev/vda /mnt/disk 2>/dev/null

# Enable swap if present on disk
if [ -f /mnt/disk/swapfile ]; then
    swapon /mnt/disk/swapfile 2>/dev/null || true
fi

# Restore packages from disk
if [ -d /mnt/disk/packages ]; then
    mkdir -p /tmp/pkg
    for pkg in /mnt/disk/packages/*.apk; do
        [ -f "$pkg" ] || continue
        cd /tmp/pkg
        tar -xzf "$pkg" 2>/dev/null
        
        # Copy only existing directories to prevent errors
        [ -d usr ] && cp -r usr/* /usr/ 2>/dev/null
        [ -d bin ] && cp -r bin/* /bin/ 2>/dev/null
        [ -d lib ] && cp -r lib/* /lib/ 2>/dev/null
        
        # Clean up contents, but keep the directory itself for the next iteration
        rm -rf /tmp/pkg/*
    done
    rm -rf /tmp/pkg
    cd /
fi

clear
echo ""

exec runsvdir /etc/runit/runsvdir/default